  "license": "MIT",
  "dependencies": {
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.4.0",
    "hono": "^4.12.12",
    "x402-stacks": "^2.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260413.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
