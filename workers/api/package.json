{
  "name": "shadowfeed-api",
  "version": "1.0.0",
  "description": "ShadowFeed API - Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:init": "wrangler d1 execute shadowfeed --file=./d1/schema.sql",
    "d1:init:local": "wrangler d1 execute shadowfeed --file=./d1/schema.sql --local"
