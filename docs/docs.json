            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/basic-agent",
              "examples/smart-agent",
              "examples/research-agent"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/x402-protocol",
              "architecture/facilitator"
            ]
          }
        ]
      },
      {
